{
  "name": "mern-boilerplate-server",
  "version": "2.0.0",
  "description": "MERN Boilerplate Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "mkdir -p build && cp -r src/* build/",
    "start-prod": "npm run build && node build/index.js",
    "docker:start:prod": "node build/index.js"
  },
